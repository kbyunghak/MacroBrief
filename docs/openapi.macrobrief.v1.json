{
  "openapi": "3.0.3",
  "info": {
    "title": "MacroBrief MVP API",
    "version": "v1"
  },
  "paths": {
    "/api/v1/dashboard/summary": {
      "get": {
        "summary": "Dashboard summary",
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/holdings": {
      "get": {"summary": "List holdings", "responses": {"200": {"description": "OK"}}},
      "post": {"summary": "Add holding", "responses": {"201": {"description": "Created"}}}
    },
    "/api/v1/holdings/{symbol}": {
      "delete": {
        "summary": "Remove holding",
        "parameters": [{"name": "symbol", "in": "path", "required": true, "schema": {"type": "string"}}],
        "responses": {"204": {"description": "No Content"}}
      }
    },
    "/api/v1/impact-cards": {
      "get": {
        "summary": "Get impact cards",
        "parameters": [{"name": "symbols", "in": "query", "schema": {"type": "string"}}],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/live-alerts": {
      "get": {
        "summary": "Get live alerts",
        "parameters": [{"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20}}],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/macro-map": {
      "get": {
        "summary": "Get macro map",
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/feedback/relevance": {
      "post": {
        "summary": "Submit relevance feedback",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["newsEventId", "symbol", "feedback"],
                "properties": {
                  "newsEventId": {"type": "string"},
                  "symbol": {"type": "string"},
                  "feedback": {"type": "string", "enum": ["relevant", "not_relevant"]}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Created"},
          "400": {"description": "Bad Request"}
        }
      }
    },
    "/api/v1/internal/ai/audit": {
      "get": {
        "summary": "Get AI guardrail audit logs (internal)",
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 20, "minimum": 1, "maximum": 100}}
        ],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/internal/ai/audit/summary": {
      "get": {
        "summary": "Get AI guardrail audit summary (internal)",
        "parameters": [
          {"name": "window", "in": "query", "schema": {"type": "integer", "default": 50, "minimum": 1, "maximum": 500}}
        ],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/events": {
      "post": {
        "summary": "Submit KPI event",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["eventId", "eventType", "userId", "occurredAtUtc", "sessionId"],
                "properties": {
                  "eventId": {"type": "string"},
                  "eventType": {"type": "string"},
                  "userId": {"type": "string"},
                  "occurredAtUtc": {"type": "string", "format": "date-time"},
                  "sessionId": {"type": "string"},
                  "symbol": {"type": "string"},
                  "newsEventId": {"type": "string"},
                  "feedback": {"type": "string"},
                  "reasonTag": {"type": "string"},
                  "sourceName": {"type": "string"},
                  "sourceUrl": {"type": "string"}
                }
              }
            }
          }
        },
        "responses": {
          "201": {"description": "Created"},
          "400": {"description": "Bad Request"}
        }
      }
    },
    "/api/v1/internal/events": {
      "get": {
        "summary": "Get recent KPI events (internal)",
        "parameters": [
          {"name": "limit", "in": "query", "schema": {"type": "integer", "default": 100, "minimum": 1, "maximum": 1000}}
        ],
        "responses": {"200": {"description": "OK"}}
      }
    },
    "/api/v1/internal/events/summary": {
      "get": {
        "summary": "Get KPI events summary (internal)",
        "parameters": [
          {"name": "window", "in": "query", "schema": {"type": "integer", "default": 200, "minimum": 1, "maximum": 1000}}
        ],
        "responses": {"200": {"description": "OK"}}
      }
    }
  }
}
